---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'dark' | 'light' | 'pure-light';
  canonical?: string;
}

const {
  title = 'Liege Milhioli | Aprimoramento Vocal para Cantores em Vila Velha',
  description = 'Aprimoramento vocal para cantores com Liege Milhioli, fonoaudióloga em Vila Velha - ES.',
  theme = 'dark',
  canonical,
} = Astro.props;

const SHOW_ELEMENT_BADGES = false;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class:list={[(theme === 'light' || theme === 'pure-light') && 'theme-light', theme === 'pure-light' && 'theme-pure-light']}
    data-theme={theme}
    data-show-element-badges={SHOW_ELEMENT_BADGES ? 'true' : 'false'}
  >
    <slot />
    <div class="page-loading-overlay" aria-live="polite" aria-hidden="true">
      <div class="page-loading-box">
        <span class="page-loading-spinner" aria-hidden="true"></span>
        <span>Carregando...</span>
      </div>
    </div>
    <script>
      type LanguageCode = 'pt' | 'en' | 'es';

      const LANGUAGES: Record<LanguageCode, { htmlLang: string; locale: string; flag: string; code: string; label: string }> = {
        pt: { htmlLang: 'pt-BR', locale: 'pt_BR', flag: '🇧🇷', code: 'PT', label: 'Português' },
        en: { htmlLang: 'en', locale: 'en_US', flag: '🇺🇸', code: 'EN', label: 'English' },
        es: { htmlLang: 'es', locale: 'es_ES', flag: '🇪🇸', code: 'ES', label: 'Español' },
      };

      const linksMeta: Record<LanguageCode, { title: string; description: string }> = {
        pt: {
          title: 'Links | Liege Milhioli',
          description: 'Canais oficiais de contato, endereço e conteúdos de Liege Milhioli em português, inglês e espanhol.',
        },
        en: {
          title: 'Links | Liege Milhioli',
          description: 'Official contact channels, address and content from Liege Milhioli in Portuguese, English and Spanish.',
        },
        es: {
          title: 'Links | Liege Milhioli',
          description: 'Canales oficiales de contacto, dirección y contenidos de Liege Milhioli en portugués, inglés y español.',
        },
      };

      const currentPageMeta = {
        title: document.title,
        description: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
      };

      const pageMetaTranslations: Record<string, Partial<Record<LanguageCode, { title: string; description: string }>>> = {
        'Liege Milhioli | Aprimoramento Vocal para Cantores em Vila Velha': {
          en: {
            title: 'Liege Milhioli | Vocal Coaching for Singers in Vila Velha',
            description: 'Vocal coaching for singers with Liege Milhioli, a speech therapist in Vila Velha - ES, focused on vocal endurance, range, vocal health and stage performance.',
          },
          es: {
            title: 'Liege Milhioli | Perfeccionamiento Vocal para Cantantes en Vila Velha',
            description: 'Perfeccionamiento vocal para cantantes con Liege Milhioli, fonoaudióloga en Vila Velha - ES, con foco en resistencia vocal, alcance, salud vocal y performance en shows.',
          },
        },
        'Liege Milhioli | Reabilitação Vocal em Vila Velha': {
          en: {
            title: 'Liege Milhioli | Vocal Rehabilitation in Vila Velha',
            description: 'Vocal rehabilitation with Liege Milhioli in Vila Velha - ES for lesions, fatigue, vocal changes and professionals who depend on their voice.',
          },
          es: {
            title: 'Liege Milhioli | Rehabilitación Vocal en Vila Velha',
            description: 'Rehabilitación vocal con Liege Milhioli en Vila Velha - ES para lesiones, fatiga, alteraciones vocales y profesionales que dependen de la voz.',
          },
        },
        'Liege Milhioli | Aperfeiçoamento da Voz Falada em Vila Velha': {
          en: {
            title: 'Liege Milhioli | Spoken Voice Improvement in Vila Velha',
            description: 'Spoken voice improvement with Liege Milhioli for communication, rhetoric, presence and performance for speakers, politicians and business leaders.',
          },
          es: {
            title: 'Liege Milhioli | Perfeccionamiento de la Voz Hablada en Vila Velha',
            description: 'Perfeccionamiento de la voz hablada con Liege Milhioli para comunicación, retórica, presencia y performance de conferencistas, políticos y empresarios.',
          },
        },
      };

      const textTranslations: Record<string, Partial<Record<LanguageCode, string>>> = {
        'Carregando...': { en: 'Loading...', es: 'Cargando...' },
        'Serviços': { en: 'Services', es: 'Servicios' },
        'Aprimoramento Vocal para Cantores': { en: 'Vocal Coaching for Singers', es: 'Perfeccionamiento Vocal para Cantantes' },
        'Reabilitação Vocal': { en: 'Vocal Rehabilitation', es: 'Rehabilitación Vocal' },
        'Aperfeiçoamento da Voz Falada': { en: 'Spoken Voice Improvement', es: 'Perfeccionamiento de la Voz Hablada' },
        'Depoimentos': { en: 'Testimonials', es: 'Testimonios' },
        'Atendimento': { en: 'Care', es: 'Atención' },
        'Contatos': { en: 'Contact', es: 'Contactos' },
        'Agendar consulta': { en: 'Schedule appointment', es: 'Agendar consulta' },
        'LIEGE MILHIOLI | FONOAUDIÓLOGA': { en: 'LIEGE MILHIOLI | SPEECH THERAPIST', es: 'LIEGE MILHIOLI | FONOAUDIÓLOGA' },
        'Especialista em aprimoramento vocal para cantores profissionais': { en: 'Specialist in vocal coaching for professional singers', es: 'Especialista en perfeccionamiento vocal para cantantes profesionales' },
        'Reabilitação vocal para recuperar segurança, conforto e resistência na voz': { en: 'Vocal rehabilitation to restore safety, comfort and endurance in the voice', es: 'Rehabilitación vocal para recuperar seguridad, comodidad y resistencia en la voz' },
        'Aperfeiçoamento da voz falada para comunicar com presença, clareza e segurança': { en: 'Spoken voice improvement to communicate with presence, clarity and confidence', es: 'Perfeccionamiento de la voz hablada para comunicar con presencia, claridad y seguridad' },
        'Fonoaudióloga': { en: 'Speech therapist', es: 'Fonoaudióloga' },
        'Anos de experiência': { en: 'Years of experience', es: 'Años de experiencia' },
        'Pacientes satisfeitos': { en: 'Satisfied patients', es: 'Pacientes satisfechos' },
        'Horas dedicadas à performance vocal': { en: 'Hours dedicated to vocal performance', es: 'Horas dedicadas a la performance vocal' },
        'Aprimoramento vocal': { en: 'Vocal coaching', es: 'Perfeccionamiento vocal' },
        'para cantores': { en: 'for singers', es: 'para cantantes' },
        'com plano individual': { en: 'with an individual plan', es: 'con plan individual' },
        'Reabilitação vocal': { en: 'Vocal rehabilitation', es: 'Rehabilitación vocal' },
        'para lesões e fadiga': { en: 'for lesions and fatigue', es: 'para lesiones y fatiga' },
        'Aperfeiçoamento': { en: 'Improvement', es: 'Perfeccionamiento' },
        'da voz falada': { en: 'of the spoken voice', es: 'de la voz hablada' },
        'para comunicação': { en: 'for communication', es: 'para comunicación' },
        '“A voz do cantor precisa responder à emoção, ao repertório e à agenda de shows sem perder cuidado técnico.”': { en: '“A singer’s voice needs to respond to emotion, repertoire and a show schedule without losing technical care.”', es: '“La voz del cantante necesita responder a la emoción, al repertorio y a la agenda de shows sin perder cuidado técnico.”' },
        '“Reabilitar a voz exige escuta, precisão e um plano possível para a rotina de quem depende dela.”': { en: '“Rehabilitating the voice requires listening, precision and a plan that fits the routine of those who depend on it.”', es: '“Rehabilitar la voz exige escucha, precisión y un plan posible para la rutina de quien depende de ella.”' },
        '“A voz falada comunica presença, intenção e segurança antes mesmo das palavras terminarem.”': { en: '“The spoken voice communicates presence, intention and confidence before the words are even finished.”', es: '“La voz hablada comunica presencia, intención y seguridad incluso antes de que terminen las palabras.”' },
        'O que é aprimoramento vocal?': { en: 'What is vocal coaching?', es: '¿Qué es el perfeccionamiento vocal?' },
        'É um acompanhamento fonoaudiológico voltado para melhorar eficiência, resistência e controle da voz cantada, respeitando a identidade vocal do artista.': { en: 'It is speech therapy support focused on improving efficiency, endurance and control of the singing voice while respecting the artist’s vocal identity.', es: 'Es un acompañamiento fonoaudiológico orientado a mejorar la eficiencia, la resistencia y el control de la voz cantada, respetando la identidad vocal del artista.' },
        'Por que é necessário?': { en: 'Why is it necessary?', es: '¿Por qué es necesario?' },
        'Porque a voz cantada exige resistência, controle e segurança para acompanhar ensaios, gravações e apresentações sem sobrecarga.': { en: 'Because the singing voice requires endurance, control and safety to handle rehearsals, recordings and performances without overload.', es: 'Porque la voz cantada exige resistencia, control y seguridad para acompañar ensayos, grabaciones y presentaciones sin sobrecarga.' },
        'Quais ganhos terei?': { en: 'What gains can I expect?', es: '¿Qué beneficios tendré?' },
        'Mais resistência, controle, alcance e confiança para cantar com menor esforço, preservando sua identidade vocal e sua performance.': { en: 'More endurance, control, range and confidence to sing with less effort while preserving your vocal identity and performance.', es: 'Más resistencia, control, alcance y confianza para cantar con menor esfuerzo, preservando tu identidad vocal y tu performance.' },
        'O que é reabilitação vocal?': { en: 'What is vocal rehabilitation?', es: '¿Qué es la rehabilitación vocal?' },
        'É o acompanhamento fonoaudiológico indicado quando há lesões, fadiga, rouquidão, desconforto ou perda de rendimento vocal.': { en: 'It is speech therapy support recommended when there are lesions, fatigue, hoarseness, discomfort or loss of vocal performance.', es: 'Es el acompañamiento fonoaudiológico indicado cuando hay lesiones, fatiga, ronquera, incomodidad o pérdida de rendimiento vocal.' },
        'Para quem é indicada?': { en: 'Who is it for?', es: '¿Para quién está indicada?' },
        'Pode ajudar cantores, professores, advogados, médicos, palestrantes e profissionais que usam a voz de forma intensa.': { en: 'It can help singers, teachers, lawyers, physicians, speakers and professionals who use their voice intensively.', es: 'Puede ayudar a cantantes, profesores, abogados, médicos, conferencistas y profesionales que usan la voz de forma intensa.' },
        'Como o plano é conduzido?': { en: 'How is the plan conducted?', es: '¿Cómo se conduce el plan?' },
        'A conduta considera avaliação vocal, rotina de uso da voz, sinais de sobrecarga e estratégias para recuperar função sem prometer resultado imediato.': { en: 'The approach considers vocal assessment, voice-use routine, signs of overload and strategies to recover function without promising immediate results.', es: 'La conducta considera evaluación vocal, rutina de uso de la voz, señales de sobrecarga y estrategias para recuperar función sin prometer resultados inmediatos.' },
        'O que é aperfeiçoamento da voz falada?': { en: 'What is spoken voice improvement?', es: '¿Qué es el perfeccionamiento de la voz hablada?' },
        'É um trabalho voltado ao uso estratégico da voz na comunicação profissional, apresentações, reuniões e fala pública.': { en: 'It is work focused on the strategic use of voice in professional communication, presentations, meetings and public speaking.', es: 'Es un trabajo orientado al uso estratégico de la voz en la comunicación profesional, presentaciones, reuniones y oratoria.' },
        'Para quem é indicado?': { en: 'Who is it for?', es: '¿Para quién está indicado?' },
