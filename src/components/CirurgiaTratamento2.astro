---
import type { ServiceSlug } from '../content/services';
import { services } from '../content/services';

interface Props {
  currentSlug?: ServiceSlug;
}

const { currentSlug = 'aprimoramento-vocal' } = Astro.props;
const tratamentos = services.filter((service) => service.slug !== currentSlug).map((service) => ({
  slug: service.slug,
  titulo: service.title,
  texto: service.cardText,
  imagem: service.cardImage,
  alt: service.cardAlt,
  href: service.path,
}));
const CARD_DESCRIPTION_MAX_LENGTH = 68;

const truncateCardDescription = (text: string) => {
  if (text.length <= CARD_DESCRIPTION_MAX_LENGTH) return text;

  const slice = text.slice(0, CARD_DESCRIPTION_MAX_LENGTH + 1);
  const lastSpace = slice.lastIndexOf(' ');
  const trimmed = text.slice(0, lastSpace > 0 ? lastSpace : CARD_DESCRIPTION_MAX_LENGTH).trim();

  return `${trimmed}...`;
};
---

<section id="cirurgia-tratamento-complementares-cards" class="outros-section" data-section="cirurgia-tratamento-complementares-cards">
  <div class="site-container">
    <h2 class="outros-title" data-element="1" data-element-name="title">
      Caminhos de cuidado para voz profissional
    </h2>

    <div class="outros-grid">
      {tratamentos.map((tratamento, index) => (
        <a class="outros-card" href={tratamento.href} data-service-slug={tratamento.slug}>
          <img
            src={tratamento.imagem}
            alt={tratamento.alt}
            class="outros-image"
            loading="lazy"
            data-element={String(index * 3 + 2)}
            data-element-name={`image-${index + 1}`}
          />
          <div class="outros-overlay" aria-hidden="true"></div>
          <div class="outros-content">
            <h3 class="outros-name" data-element={String(index * 3 + 3)} data-element-name={`card-title-${index + 1}`}>
              {tratamento.titulo}
            </h3>
            <p class="outros-text" data-element={String(index * 3 + 4)} data-element-name={`card-description-${index + 1}`}>
              {truncateCardDescription(tratamento.texto)}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .outros-section {
    background: #181818;
    padding-top: clamp(4.5rem, 7vw, 6.5rem);
    padding-bottom: clamp(4rem, 6vw, 5rem);
    font-family: 'Manrope', sans-serif;
  }

  .outros-title {
    color: #FFFFFF;
    font-size: var(--font-section-title);
    font-weight: var(--font-section-title-weight);
    line-height: var(--font-section-title-line-height);
    letter-spacing: var(--font-section-title-letter-spacing);
    text-align: center;
    margin: 0 0 clamp(3.5rem, 6vw, 4.75rem);
  }

  .outros-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.75rem;
  }

  .outros-card {
    position: relative;
    display: block;
    min-height: 390px;
    overflow: hidden;
    background: #202020;
    text-decoration: none;
    transition: transform 260ms ease, box-shadow 260ms ease;
  }

  .outros-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
  }

  .outros-card[data-service-slug="aprimoramento-vocal"] .outros-image {
    object-position: 22% center;
  }

  .outros-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.1) 58%, rgba(0, 0, 0, 0.72) 100%);
    transition: background 260ms ease;
  }

  .outros-content {
    position: absolute;
    left: 50%;
    bottom: 25px;
    transform: translateX(-50%);
    width: min(84%, 430px);
    display: grid;
    gap: 0.7rem;
    text-align: center;
  }

  .outros-name {
    background: rgba(236, 239, 243, 0.88);
    color: #111113;
    font-size: var(--font-subsection-title);
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
    padding: 0.62rem 1.25rem;
    transition: background 260ms ease, color 260ms ease;
  }

  .outros-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.32);
  }

  .outros-card:hover .outros-overlay {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.04) 0%, rgba(0, 0, 0, 0.18) 52%, rgba(0, 0, 0, 0.82) 100%);
  }

  .outros-card:hover .outros-name {
    background: rgba(255, 255, 255, 0.94);
    color: #0f0f10;
  }

  .outros-text {
    color: rgba(255, 255, 255, 0.84);
    font-size: 1rem;
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 1024px) {
    .outros-card {
      min-height: 340px;
    }
  }

  @media (max-width: 767px) {
    .outros-section {
      padding-block: 4rem;
    }

    .outros-title {
      margin-bottom: 2.5rem;
    }

    .outros-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .outros-card {
      min-height: 320px;
    }

    .outros-text {
      font-size: 0.92rem;
    }

    .outros-content {
      bottom: 22px;
    }

    .outros-name {
      padding-block: 0.56rem;
    }
  }
</style>
