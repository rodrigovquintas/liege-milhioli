---
import {
  ArrowUpRight,
  BookOpen,
  Camera,
  ChevronDown,
  GraduationCap,
  Leaf,
  MapPin,
  Menu,
  MessageCircle,
  Phone,
  Plane,
  Play,
  Send,
  ShieldCheck,
  Sparkles,
  Users,
} from 'lucide';
import type { IconNode } from 'lucide';
import { siInstagram, siTiktok, siUber, siWaze, siWhatsapp, siYoutube } from 'simple-icons';
import type { SimpleIcon } from 'simple-icons';

interface Props {
  name: keyof typeof iconMap | keyof typeof brandMap;
  size?: number;
  strokeWidth?: number;
  class?: string;
}

const {
  name,
  size = 24,
  strokeWidth = 1.8,
  class: className,
  ...rest
} = Astro.props as Props;

const iconMap: Record<string, IconNode> = {
  'arrow-up-right': ArrowUpRight,
  book: BookOpen,
  camera: Camera,
  'chevron-down': ChevronDown,
  graduation: GraduationCap,
  leaf: Leaf,
  map: MapPin,
  menu: Menu,
  message: MessageCircle,
  phone: Phone,
  plane: Plane,
  play: Play,
  send: Send,
  shield: ShieldCheck,
  spark: Sparkles,
  users: Users,
};

const brandMap: Record<string, SimpleIcon> = {
  instagram: siInstagram,
  tiktok: siTiktok,
  uber: siUber,
  waze: siWaze,
  whatsapp: siWhatsapp,
  youtube: siYoutube,
};

const LucideIcon = iconMap[name];
const BrandIcon = brandMap[name];
---

{LucideIcon && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
    {...rest}
  >
    {LucideIcon.map(([Tag, attrs]: IconNode[number]) => <Tag {...attrs} />)}
  </svg>
)}
{BrandIcon && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="currentColor"
    class:list={['brand-icon', className]}
    aria-hidden="true"
    {...rest}
  >
    <path d={BrandIcon.path} />
  </svg>
)}
