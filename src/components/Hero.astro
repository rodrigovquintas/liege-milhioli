---
import Icon from './Icon.astro';

interface Props {
  title?: string;
  heroImage?: string;
  heroMobileImage?: string;
}

const {
  title = 'Especialista em aprimoramento vocal para cantores profissionais',
  heroImage = '/images/herorenato.webp',
  heroMobileImage = heroImage,
} = Astro.props;
const WA_LINK = "/whatsapp-website";
---

<section
  id="hero-section"
  class="hero-section"
  data-section="hero"
  style={`--hero-image: url('${heroImage}')`}
>
  <div class="hero-inner site-container">

    <!-- Small label: 16px, 600, uppercase, #CFD2D8 -->
    <p class="hero-label" data-element="1" data-element-name="label">LIEGE MILHIOLI | FONOAUDIÓLOGA</p>

    <!-- Big title: 64px, 400, #FFFFFF -->
    <h1 class="hero-title" data-element="2" data-element-name="title">{title}</h1>

    <!-- CTA: bg #FFFFFF, color #1B1B1D, border-radius 32px, icon right -->
    <a href={WA_LINK} class="btn-cta" data-element="3" data-element-name="cta">
      <span class="btn-icon-wrap">
        <Icon name="whatsapp" size={21} />
      </span>
      Agendar consulta
    </a>

    <img
      class="hero-mobile-image"
      src={heroMobileImage}
      alt=""
      loading="eager"
      aria-hidden="true"
      data-element="4"
      data-element-name="mobile-image"
    />

  </div>
</section>

<style>
  .hero-section {
    background-image: var(--hero-image);
    background-position: top center;
    background-size: cover;
    background-repeat: no-repeat;
    background-color: #181818;
    padding-top: clamp(10rem, 20vw, 17.5rem);
    padding-bottom: clamp(6.25rem, 12vw, 11.25rem);
    font-family: 'Manrope', sans-serif;
  }

  .hero-inner {
    position: relative;
  }

  .hero-label {
    color: #CFD2D8;
    font-size: var(--font-label);
    font-weight: 600;
    text-transform: uppercase;
    line-height: 1.55em;
    letter-spacing: 2.56px;
    margin: 0 0 0 0;
  }

  .hero-title {
    color: #FFFFFF;
    font-size: var(--font-display-hero);
    font-weight: 400;
    line-height: 1.1em;
    margin: 0 0 var(--space-9);
    max-width: 850px;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    flex-direction: row-reverse;
    gap: var(--cta-gap);
    background-color: #FFFFFF;
    color: #1B1B1D;
    border-radius: 32px;
    padding: var(--cta-block) var(--cta-inline);
    font-size: var(--font-cta);
    font-weight: 600;
    font-family: 'Manrope', sans-serif;
    text-decoration: none;
    transition: background-color 0.5s;
  }
  .btn-cta:hover { background-color: #E9E9E9; }
  .btn-icon-wrap {
    display: flex;
    align-items: center;
    font-size: var(--font-icon-cta);
  }

  .hero-mobile-image {
    display: none;
  }

  @media (max-width: 767px) {
    .hero-section {
      background-image: none;
      padding-top: clamp(7.5rem, 22vw, 9rem);
      padding-bottom: 0;
      overflow: hidden;
    }

    .hero-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-title {
      margin-bottom: var(--space-7);
    }

    .hero-mobile-image {
      display: block;
      width: 100vw;
      max-width: none;
      height: auto;
      align-self: center;
      margin-top: var(--space-8);
      margin-inline: calc(50% - 50vw);
    }
  }

</style>
