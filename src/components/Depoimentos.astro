<section id="depoimentos" class="dep-section" data-section="depoimentos">
  <div class="site-container">
    <div class="dep-header">
      <p class="dep-label" data-element="1" data-element-name="label">depoimentos</p>
      <h2 class="dep-title" data-element="2" data-element-name="title">Trajetória construída com voz, técnica e performance</h2>
    </div>

    <div class="swiper depoimentos-swiper depoimentos-swiper-desktop">
      <div class="swiper-wrapper">
        {chunks.map((group, groupIndex) => (
          <div class="swiper-slide">
            <div class="dep-slide-grid">
              {group.map((dep, depIndex) => (
                <article
                  class="dep-card"
                  data-element={String(groupIndex * 6 + depIndex + 3)}
                  data-element-name={`review-card-${groupIndex * 6 + depIndex + 1}`}
                >
                  <div class="dep-stars" aria-label="Avaliação 5.0 de 5">
                    <span class="dep-score">5.0</span>
                    <span class="dep-stars-text">★★★★★</span>
                  </div>
                  <div class="dep-card-body">
                    <p class="dep-texto">{dep.texto}</p>
                  </div>
                  <div class="dep-card-footer">
                    <p class="dep-nome">{dep.nome}</p>
                    <p class="dep-google">{dep.fonte ?? 'Avaliação pública extraída do Google'}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="dep-controls">
        <div class="swiper-pagination dep-pagination" data-element="21" data-element-name="pagination"></div>
      </div>
    </div>

    <div class="swiper depoimentos-swiper depoimentos-swiper-mobile">
      <div class="swiper-wrapper">
        {depoimentos.map((dep, depIndex) => (
          <div class="swiper-slide">
            <article
              class="dep-card"
              data-element={String(depIndex + 3)}
              data-element-name={`review-card-${depIndex + 1}`}
            >
              <div class="dep-stars" aria-label="Avaliação 5.0 de 5">
                <span class="dep-score">5.0</span>
                <span class="dep-stars-text">★★★★★</span>
              </div>
              <div class="dep-card-body">
                <p class="dep-texto">{dep.texto}</p>
              </div>
              <div class="dep-card-footer">
                <p class="dep-nome">{dep.nome}</p>
                <p class="dep-google">{dep.fonte ?? 'Avaliação pública extraída do Google'}</p>
              </div>
            </article>
          </div>
        ))}
      </div>
      <div class="dep-controls">
        <button class="dep-nav-button dep-nav-prev" type="button" aria-label="Depoimento anterior" data-element="21" data-element-name="previous-review">
          <span aria-hidden="true">‹</span>
        </button>
        <button class="dep-nav-button dep-nav-next" type="button" aria-label="Próximo depoimento" data-element="22" data-element-name="next-review">
          <span aria-hidden="true">›</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import 'swiper/css';
  import 'swiper/css/pagination';
  import 'swiper/css/navigation';
</script>

<script>
  import Swiper from 'swiper';
  import { Pagination, Navigation, Autoplay } from 'swiper/modules';

  document.addEventListener('DOMContentLoaded', () => {
    const createDepoimentosSwiper = (selector: string) => new Swiper(selector, {
      modules: [Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 32,
      loop: false,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
        waitForTransition: true,
      },
      pagination: { el: `${selector} .dep-pagination`, clickable: true },
    });

    const desktopSwiper = createDepoimentosSwiper('.depoimentos-swiper-desktop');
    const mobileSwiper = new Swiper('.depoimentos-swiper-mobile', {
      modules: [Navigation, Autoplay],
      slidesPerView: 1,
      spaceBetween: 32,
      autoHeight: true,
      loop: false,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
        waitForTransition: true,
      },
      navigation: {
        prevEl: '.depoimentos-swiper-mobile .dep-nav-prev',
        nextEl: '.depoimentos-swiper-mobile .dep-nav-next',
      },
    });

    const cards = document.querySelectorAll('#depoimentos .dep-card');
    const pause = () => {
      desktopSwiper.autoplay?.pause();
      mobileSwiper.autoplay?.pause();
    };
    const resume = () => {
      desktopSwiper.autoplay?.resume();
      mobileSwiper.autoplay?.resume();
    };

    cards.forEach((card) => {
      card.addEventListener('mouseenter', pause);
      card.addEventListener('mouseleave', resume);
      card.addEventListener('click', pause);
      card.addEventListener('focusin', pause);
      card.addEventListener('touchstart', pause, { passive: true });
    });
  });
</script>

<style>
  .dep-section {
    background-color: #191919;
    padding-top: var(--section-space-lg);
    padding-bottom: var(--section-space-xl);
    font-family: 'Manrope', sans-serif;
    overflow: hidden;
  }

  .dep-header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 4.375rem);
    padding: 0 var(--space-5);
  }

  .dep-label {
    color: #CFD2D8;
    font-size: var(--font-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.56px;
    line-height: 1.5em;
    margin: 0 0 20px;
  }

  .dep-title {
    color: #FFFFFF;
    font-size: var(--font-section-title);
    font-weight: var(--font-section-title-weight);
    line-height: var(--font-section-title-line-height);
    letter-spacing: var(--font-section-title-letter-spacing);
    margin: 0;
  }

  .depoimentos-swiper {
    position: relative;
    padding: 0 0 clamp(3.5rem, 6vw, 4.375rem);
    --swiper-theme-color: #b8bcc2;
    --swiper-pagination-color: #b8bcc2;
  }

  .depoimentos-swiper-mobile {
    display: none;
  }

  .swiper-slide {
    height: auto;
  }

  .dep-slide-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gap) var(--grid-gap-lg);
    --dep-card-height: 265px;
    --dep-row-gap: 32px;
  }

  .dep-card {
    height: var(--dep-card-height);
    background-color: #242426;
    border-radius: 2px;
    padding: clamp(1rem, 2vw, 1.125rem) clamp(1.25rem, 3vw, 1.5rem) var(--space-5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .dep-card-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    padding-right: 8px;
    scrollbar-width: thin;
    scrollbar-color: #4B4B4D transparent;
  }

  .dep-card-body::-webkit-scrollbar {
    width: 7px;
  }

  .dep-card-body::-webkit-scrollbar-track {
    background: transparent;
  }

  .dep-card-body::-webkit-scrollbar-thumb {
    background: #4B4B4D;
    border-radius: 999px;
  }

  .dep-stars {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }

  .dep-score {
    color: #CFD2D8;
    font-size: var(--font-body-sm);
    line-height: 1;
  }

  .dep-stars-text {
    color: #F9CE7A;
    font-size: var(--font-body);
    letter-spacing: 2px;
    line-height: 1;
  }

  .dep-texto {
    color: #FFFFFF;
    font-size: var(--font-body);
    font-weight: 400;
    line-height: 1.55em;
    margin: 0;
  }

  .dep-nome {
    color: #CFD2D8;
    font-size: var(--font-body);
    font-weight: 500;
    line-height: 1.4em;
    margin: 0 0 8px;
  }

  .dep-google {
    color: #8E9198;
    font-size: var(--font-caption);
    font-weight: 400;
    line-height: 1.4;
    margin: 0;
  }

  .dep-card-footer {
    margin-top: var(--space-3);
    flex-shrink: 0;
    padding-top: var(--space-3);
    background: #242426;
  }

  .dep-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-9);
  }

  .dep-pagination {
    position: static !important;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .dep-pagination :global(.swiper-pagination-bullet) {
    background-color: #6f757d !important;
    opacity: 1 !important;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    transition: background 0.3s ease;
  }

  .dep-pagination :global(.swiper-pagination-bullet-active) {
    background-color: #c8ccd2 !important;
  }

  .dep-nav-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: #242426;
    color: #FFFFFF;
    cursor: pointer;
    line-height: 1;
    transition: background-color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .dep-nav-button span {
    display: block;
    font-size: 2rem;
    line-height: 0.8;
    transform: translateY(-1px);
  }

  .dep-nav-button:hover,
  .dep-nav-button:focus-visible {
    background: #2D2D2E;
    border-color: rgba(255, 255, 255, 0.34);
  }

  .dep-nav-button:global(.swiper-button-disabled) {
    cursor: default;
    opacity: 0.38;
  }

  @media (max-width: 1024px) {
    .depoimentos-swiper { padding: 0 0 64px; }
    .dep-slide-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 28px;
      --dep-row-gap: 28px;
    }
  }

  @media (max-width: 767px) {
    .dep-section {
      padding-bottom: clamp(2rem, 10vw, 3rem);
    }

    .dep-header { padding: 0; }

    .depoimentos-swiper-desktop {
      display: none;
    }

    .depoimentos-swiper-mobile {
      display: block;
      padding: 0;
    }

    .depoimentos-swiper-mobile .dep-controls {
      justify-content: space-between;
      margin-top: 12px;
    }

    .depoimentos-swiper-mobile .dep-nav-button {
      width: 42px;
      height: 42px;
    }
  }
</style>
